from karel.stanfordkarel import *

"""
The warmup program defines a "main"
function which should make Karel
pick up all the beepers in the world.
"""

def main():
    for i in range(3):
        move()
        for j in range(10):
            pick_beeper()
        move()

# RESOLUTIONS FROM THE PROBLEM REWIEW 
    #1: FOR LOOP

def main():
    move()
    for i in range(3):
        pick_and_move()

def pick_pile_up():
    for i in range(10):
        pick_beeper()

def move_to_next_pile():
    for i in range(2):
        if front_is_clear():
            move()

def pick_and_move():
    pick_pile_up()
    move_to_next_pile()

    #2: WHILE LOOP

def main():
    while front_is_clear():
        move()
        pick_pile_up_2()

def pick_pile_up_2():
    while beepers_present():
        pick_beeper()
  
if __name__ == '__main__':
    main()
