from karel.stanfordkarel import *

"""
The warmup program defines a "main" function which should make Karel 
move to the beeper, pick it up, and return home.
"""

def main():
    move_pick()
    return_home()

def move_pick(): #move and pick beeper
    turn_right() 
    move()
    turn_left()
    move()
    move()
    move()
    pick_beeper()

def return_home(): #return home
    turn_left() 
    turn_left()
    move()
    move()
    move()
    turn_right()
    move()
    turn_right()
    
def turn_right():
    turn_left()
    turn_left()
    turn_left()

if __name__ == '__main__':
    main()
