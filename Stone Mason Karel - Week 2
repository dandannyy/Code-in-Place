from karel.stanfordkarel import *

"""
When you finish writing this file, Karel should have repaired 
each of the columns in the temple
"""

def main():
    while front_is_clear():
        do_one_column()
    do_one_column()

def do_one_column():
    turn_left()
    put_five_beepers()
    return_to_base()
    turn_left()
    four_steps()

def put_five_beepers():
    while front_is_clear():
        put_beeper()
        move()
    put_beeper()

def return_to_base():
    turn_around()
    move_to_wall()

def turn_around():
    turn_left()
    turn_left()

def four_steps():
    if front_is_clear():
        for i in range(4):
            move()
        
def move_to_wall():
    while front_is_clear():
        move()

if __name__ == '__main__':
    main()
