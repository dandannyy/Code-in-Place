import random

"""
Write a program which takes as input the number of sides on a dice.  
Then, simulate rolling a dice with that many sides. Print the outcome of the roll.
"""

def main():
    your_dice = input("How many sides does your dice have? ")
    your_dice = int(your_dice)
    your_roll = random.randint(1, your_dice)
    print("Your roll is", your_roll)

if __name__ == '__main__':
    main()
