from ai import call_gpt

"""
Write a program to create a Haiku, using ai.
Prompt the user to enter their name, and a topic. 
Then make use call_gpt to turn the name and topic into a haiku. We leave it up to you to come up with the prompt! 
"""

def main():
    your_name = input("Enter your name: ")
    your_topic = input("Enter a topic: ")
    print("Creating your haiku...")
    haiku = call_gpt(f"You can create a haiku with {your_topic} and {your_name}")
    print(haiku)


if __name__ == "__main__":
    main()
